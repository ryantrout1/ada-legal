# Example environment variables. Copy to .env.local and fill in real values.
# Production values are set in Vercel project env vars, not committed.

# ─── Clerk ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
CLERK_SECRET_KEY=sk_live_your_secret_key_here

# ─── Neon Postgres ──────────────────────────────────────────────────────────
# Get from Neon dashboard → your project → Connection Details
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
