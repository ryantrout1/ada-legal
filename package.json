{
  "name": "ada-legal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ADA Legal Link — Ada engine, attorney directory, and enterprise ADA intake platform.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:personas": "playwright test",
    "test:personas:preview": "PLAYWRIGHT_TARGET=preview playwright test",
    "test:personas:install": "playwright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@clerk/backend": "^3.2.13",
    "@clerk/clerk-react": "^5.61.5",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.7.12",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.7.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
