{
  "name": "ada-legal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ADA Legal Link — Ada engine, attorney directory, and enterprise ADA intake platform.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:personas": "playwright test tests/personas"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
